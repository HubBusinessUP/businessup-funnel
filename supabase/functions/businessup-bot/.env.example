# Business UP — Edge Function "businessup-bot"
# Segreti richiesti. NON committare i valori reali.
# Impostali su Supabase: Dashboard → Edge Functions → Secrets
# oppure via CLI:  supabase secrets set --env-file ./supabase/functions/businessup-bot/.env

# Token del bot Telegram (da @BotFather). RIGENERARLO: il precedente è stato esposto.
BOT_TOKEN=

# Telegram ID dell'amministratore (numerico)
ADMIN_ID=334179105

# Username del bot, senza @ (opzionale, default: BotBusinessUP_bot)
BOT_USERNAME=BotBusinessUP_bot

# Secret del webhook Telegram (header x-telegram-bot-api-secret-token)
WEBHOOK_SECRET=

# Chiave API per le rotte admin/CRM (header x-admin-key)
ADMIN_API_KEY=

# Secret per la rotta cron-followup (querystring ?key=)
CRON_SECRET=

# Forniti automaticamente da Supabase in runtime (NON serve impostarli a mano):
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
